{var $condition = true}

{* Simple if/else — variable defined in both branches, used after *}
{if $condition}
    {var $a = 'hello'}
{else}
    {var $a = 'world'}
{/if}
{$a}

{* Nested: if/else inside a block, variable used after if/else but still inside block *}
{block content}
    {if $condition}
        {var $b = 1}
    {else}
        {var $b = 2}
    {/if}
    {$b}
{/block}

{* Double nesting: if/else inside if/else *}
{if $condition}
    {if $condition}
        {var $c = 1}
    {else}
        {var $c = 2}
    {/if}
    {$c}
{else}
    {var $c = 3}
    {$c}
{/if}